# IronCoach Environment Configuration
# Copy this file to .env and edit as needed:
#   cp .env.example .env

# Server port (default: 8000)
# PORT=8000

# Claude CLI binary name or path (default: 'claude' from PATH)
# Use this if your CLI has a different name or you use a wrapper script.
# CLAUDE_CLI=ai
# CLAUDE_CLI=/usr/local/bin/my-claude-wrapper

# AWS profile for Claude API via Bedrock (optional)
# CLAUDE_AWS_PROFILE=my-profile
